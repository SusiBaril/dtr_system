<div>
    <h1 class="text-4xl font-bold text-center mt-10">Welcome to the Attendance and Task Management System</h1>
    <p class="text-center mt-4 text-lg">Manage your attendance and tasks efficiently with our user-friendly interface.</p>
</div>

<%# Analytics for Attendance Status, Working Hour and Remaining Hours %>
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-10">

    <!-- Time In -->
    <div class="bg-white shadow-lg rounded-2xl p-6 border-l-8 border-green-500">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-gray-500 text-sm">Attendance Status</p>
                <h1 class="text-3xl font-bold text-gray-800" id="log">Logged Out</h1>
            </div>
        </div>
    </div>

    <!-- Time Out -->
    <div class="bg-white shadow-lg rounded-2xl p-6 border-l-8 border-red-500">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-gray-500 text-sm">Today's Working Hours</p>
                <h1 id="timer" class="text-3xl font-bold text-gray-800">00:00:00</h1>
            </div>
        </div>
    </div>

    <!-- Remaining Hours -->
    <div class="bg-white shadow-lg rounded-2xl p-6 border-l-8 border-blue-500">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-gray-500 text-sm">Remaining Hours</p>
                <h1 class="text-3xl font-bold text-gray-800">120 hrs</h1>
                <p class="text-blue-500 text-sm mt-1">Target: 486 hrs</p>
            </div>
        </div>
    </div>

</div>

<div class="flex justify-center items-center mt-16">
  <% if @timed_in %>
    <%= form_with url: time_out_path, method: :post, local: true, data: { turbo: false } do |f| %>
      <%= f.submit "Time Out",
        class: "bg-red-500 hover:bg-red-600 text-white text-4xl font-bold py-10 px-20 rounded-full shadow-2xl" %>
    <% end %>
  <% else %>
    <%= form_with url: time_in_path, method: :post, local: true, data: { turbo: false } do |f| %>
      <%= f.submit "Time In",
        class: "bg-green-500 hover:bg-green-600 text-white text-4xl font-bold py-10 px-20 rounded-full shadow-2xl" %>
    <% end %>
  <% end %>
</div>

<script>
  const startTime = <%= @start_time_ms || 'null' %>;
  const timedIn = <%= @timed_in ? 'true' : 'false' %>;
</script>

<div>
    <div class="text-center uppercase text-2xl">
        <h2 class="text-2xl font-bold mt-10">Attendance History</h2>
    </div>
    <table class="border border-black w-full mt-10">
        <tr class="border border-black">
            <th class="p-3 text-lg">Date</th>
            <th class="p-3 text-lg">Time In</th>
            <th class="p-3 text-lg">Time Out</th>
            <th class="p-3 text-lg">Rendered Hour</th>
        </tr>

        <% if @attendances.empty? %>
            <tr class="border border-black">
                <td colspan="4" class="p-3 text-center text-gray-500">No attendance records found.</td>
            </tr>
        <% else %>
            <% @attendances&.each do |attendance| %>  <!-- Use & to check for nil -->
                <tr class="border border-black text-center">
                    <td class="p-3"><%= attendance.date.strftime('%Y-%m-%d') %></td>
                    <td class="p-3"><%= attendance.time_in&.in_time_zone('Asia/Manila')&.strftime('%I:%M %p') || 'N/A' %></td>
                    <td class="p-3"><%= attendance.time_out&.in_time_zone('Asia/Manila')&.strftime('%I:%M %p') || 'N/A' %></td>
                    <td class="p-3"><%= attendance.rendered_hours&.round(2) || 'N/A' %> hrs</td>
                </tr>
            <% end %>
        <% end %>
        
    </table>
</div>


<%# Script for the Button Toggle, Time Counter and Logged In and Logged Out %>
<script>
document.addEventListener("DOMContentLoaded", () => {
    const timerDisplay = document.getElementById("timer");
    const log = document.getElementById("log");

    let interval;
    let startTime = <%= @start_time_ms || 'null' %>;
    let timedIn = <%= @timed_in ? 'true' : 'false' %>;

    function format(ms) {
        const hours = String(Math.floor(ms / 3600000)).padStart(2, "0");
        const minutes = String(Math.floor((ms % 3600000) / 60000)).padStart(2, "0");
        const seconds = String(Math.floor((ms % 60000) / 1000)).padStart(2, "0");
        return `${hours}:${minutes}:${seconds}`;
    }

    function tick() {
        if (startTime) {
            const elapsed = Date.now() - startTime;
            timerDisplay.textContent = format(elapsed);
        }
    }

    function start() {
        clearInterval(interval);
        interval = setInterval(tick, 1000);
        tick();
    }

    function init() {
        log.textContent = timedIn ? "Logged In" : "Logged Out";
        if (timedIn && startTime) {
            start();
        } else {
            timerDisplay.textContent = "00:00:00";
        }
    }

    init();
});
</script>