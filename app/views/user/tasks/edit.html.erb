<h1>Edit Task</h1>
<%= form_with model: @task, url: user_task_path(@task), method: :patch do |f| %>
  <div>
    <%= f.label :name %>
    <%= f.text_field :name %>
  </div>
  <div>
    <%= f.label :date %>
    <%= f.date_field :date %>
  </div>
  <%= f.submit 'Update Task' %>
<% end %>
<%= link_to 'Back to Tasks', user_tasks_path %>