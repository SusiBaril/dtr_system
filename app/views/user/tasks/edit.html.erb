<div class="flex items-center justify-center p-6">
  <div class="w-full max-w-xl bg-white shadow-lg rounded-2xl">
    <div class="flex items-center justify-center p-6">
      <h1 class="text-2xl font-bold uppercase">Edit Task</h1>
    </div>

  <%= form_with model: [:user, @task], class: "space-y-6" do |f| %>

      <div class="mb-4 px-5">
        <label class="block mb-1 font-medium">Date</label>

        <input type="text"
              value="<%= @task.attendance&.date %>"
              disabled
              class="w-full border rounded px-3 py-2 bg-gray-100" />
      </div>

      <div class="mb-4 px-5">
        <%= f.label :description, class: "block mb-1 font-medium" %>

        <%= f.text_area :description,
            class: "w-full border rounded px-3 py-2 h-32" %>
      </div>

      <div class="flex items-center justify-center gap-10">
        <div class="px-2 m-2 bg-green-300 rounded hover:bg-green-400">
          <%= f.submit "Update Task",
              class: "px-4 py-2 cursor-pointer" %>
        </div>

        <div class="p-2 m-2 bg-blue-300 rounded hover:bg-blue-400">
          <%= link_to "Back to Tasks", user_tasks_path, class: "px-4 py-2 cursor-pointer" %>
        </div>
      </div>

    <% end %>
  </div>
</div>