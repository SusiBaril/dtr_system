<div class="flex items-center justify-center">
    <h1 class="text-5xl uppercase font-bold">Daily Task</h1>
</div>

<div class="mt-5">
<table class="border border-black w-full mt-10 border-collapse">
    <tr class="border border-black">
        <th class="p-3 text-left">Date</th>
        <th class="p-3 text-center">Task</th>
        <th class="p-3 text-right">Actions</th>
    </tr>

    <% if @tasks.empty? %>
        <tr>
            <td colspan="3" class="p-3 text-center">
                No tasks available
            </td>
        </tr>
    <% else %>
        <% @tasks.each do |task| %>
            <tr class="border border-black">
                <td class="p-3">
                    <%= task.attendance&.date&.strftime('%Y-%m-%d') || 'N/A' %>
                </td>

                <td class="p-3 text-center">
                    <%= task.title || 'No Daily Task' %>
                </td>

                <td class="p-3">
                    <div class="flex justify-end items-end gap-2">

                    <%= link_to 'View', user_task_path(task), class: "text-blue-600" %>

                    <%= link_to 'Edit', edit_user_task_path(task), class: "text-green-600" %>

                    <%= button_to 'Delete',
                        user_task_path(task),
                        method: :delete,
                        class: "text-red-600",
                        form: { class: "inline" } %>

                    </div>
                </td>
            </tr>
        <% end %>
    <% end %>
</table>

</div>