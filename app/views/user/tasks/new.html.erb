<h1>New Task</h1>

<%= form_with model: [:user, @task] do |f| %>
  <div>
    <%= f.label :title %>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :description %>
    <%= f.text_area :description %>
  </div>

  <%= f.submit 'Create Task' %>
<% end %>

<%= link_to 'Back to Tasks', user_tasks_path %>