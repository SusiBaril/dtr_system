<h1>New Task</h1>
<%= form_with model: @task, url: user_tasks_path, method: :post do |f| %>
  <div>
    <%= f.label :name %>
    <%= f.text_field :name %>
  </div>
  <div>
    <%= f.label :date %>
    <%= f.date_field :date %>
  </div>
  <%= f.submit 'Create Task' %>
<% end %>
<%= link_to 'Back to Tasks', user_tasks_path %>